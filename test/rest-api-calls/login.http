Content-Type: application/json 

{
    "username" : "uwuw",
    "password" : "Word&Uwu1819"
}

{{
    $global.jwtToken=response.parsedBody.access_token;
}}

# @name create
POST http://0.0.0.0:3000/users/sign-up HTTP/1.1
Content-Type: application/json 

{
